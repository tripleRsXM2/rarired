# CourtSync — environment variable template
# Copy to .env.local for local dev; set the same keys in Vercel
# (preview + production) for deployed environments.

# ─── Supabase (client) ───────────────────────────────────────────────
# Anon key only — never put the service role key in any VITE_* var.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Web Push (Module 8) ─────────────────────────────────────────────
# VAPID public key. base64url, no padding. Generated together with the
# private key — only the PUBLIC half is safe to expose to the client.
# NEVER put VAPID_PRIVATE_KEY into a VITE_* env var.
#
# Generate locally:
#   npx web-push generate-vapid-keys
#
# Set the public key here (and in Vercel preview + production env).
# Set the PRIVATE key + the same PUBLIC key as Supabase secrets:
#   supabase secrets set --linked \
#     VAPID_PUBLIC_KEY=...  VAPID_PRIVATE_KEY=...  VAPID_SUBJECT=mailto:ops@courtsync.app
VITE_VAPID_PUBLIC_KEY=
